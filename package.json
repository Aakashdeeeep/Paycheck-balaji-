{
  "name": "payroll-manager",
  "version": "1.0.0",
  "description": "Desktop Payroll Management System",
  "main": "main/main.js",
  "scripts": {
    "dev": "npx kill-port 4821 --silent; concurrently -k \"npm run dev:renderer\" \"wait-on tcp:4821 && npm run dev:electron\"",
    "dev:renderer": "vite renderer --port 4821 --strictPort",
    "dev:electron": "env -u ELECTRON_RUN_AS_NODE cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build renderer",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build": "npm run build:renderer && electron-builder",
    "pack": "npm run build:renderer && electron-builder --dir",
    "seed": "node scripts/seed.js"
  },
  "keywords": [],
  "author": "Your Business",
  "license": "ISC",
  "build": {
    "appId": "com.balaji.payrollmanager",
    "productName": "Payroll Manager",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "npmRebuild": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "assets/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Payroll Manager",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.2",
    "playwright-core": "^1.60.0",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.0",
    "xlsx": "^0.18.5"
  }
}
